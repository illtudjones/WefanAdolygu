            "back": "Continuous data represented physically"
        },
        {
            "front": "What is digital data?",
            "back": "Discrete data stored as binary"
        },
        {
            "front": "What does sample rate measure?",
            "back": "Number of samples taken per second"
        },
        {
            "front": "What is sample resolution?",
            "back": "Number of bits used per sample"
        },
        {
